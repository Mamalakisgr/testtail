{
    "builds": [
      { "src": "test/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } },
      { "src": "test/testbackend/server.js", "use": "@vercel/node" }
    ],
    "routes": [
      { "src": "/api/(.*)", "dest": "test/testbackend/server.js" },
      { "src": "/(.*)", "dest": "test/dist/$1" }
    ]
  }
  