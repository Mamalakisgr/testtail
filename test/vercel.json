{
  "builds": [
    { "src": "testbackend/server.js", "use": "@vercel/node" },
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/dist/$1" }
  ],
  "rewrites": [{ "source": "/api/(.*)", "destination": "/testbackend/server.js" }]

}
